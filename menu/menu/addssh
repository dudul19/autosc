echo -e "https://$domain:81/ssh-$user.txt"
echo -e "========="
echo -e "Create at        : $tnggl"
echo -e "Expired          : $expe"
echo -e "========="
echo ""
read -n 1 -s -r -p "Press any key to back"
m-ssh
