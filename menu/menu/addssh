CHATID=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 3)
KEY=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 2)
export TIME="10"
export URL="https://api.telegram.org/bot$KEY/sendMessage"
sensor=$(echo "$user" | sed 's/\(.\{3\}\).*/\1xxx/')
ISP=$(curl -s ipinfo.io/org | cut -d " " -f 2-10 )
TEXT="
<b>=========</b>
<b>❖ TRANSACTION SUCCESSFULL  </b>
<b>=========</b>
<b>Product     :</b> SSH
<b>ISP         :</b> <code>${ISP}</code>
<b>Limit Quota :</b> <code>${Quota} GB</code>
<b>Limit Login :</b> <code>${iplimit} IP</code>
<b>Username    :</b> <code>${sensor}</code>
<b>Duration    :</b> <code>${masaaktif} Days</code>
<b>=========</b>
"
curl -s --max-time $TIME -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" $URL >/dev/null
clear

echo -e "========="
echo -e "SSH Account"
echo -e "========="
echo -e "Username         : $user"
echo -e "Password         : $Pass"
echo -e "========="
echo -e "SSH : $domain:443@$user:$Pass"
echo -e "UDP : $domain:1-65535@$user:$Pass"
echo -e "========="
echo -e "Host             : $domain"
echo -e "Host Slowdns     : ${NS}"
echo -e "Limit Quota      : $Quota GB"
echo -e "Limit IP         : ${iplimit} IP"
echo -e "========="
echo -e "Pub Key          : ${PUB}"
echo -e "Port OpenSSH     : 22"
echo -e "Port DNS         : 53 ,2222"
echo -e "Port SSH UDP     : 1-65535"
echo -e "Port Dropbear    : 22, 109"
echo -e "Port SSH WS      : 80,8080,2086,8880"
echo -e "Port SSH WS SSL  : 443,8443"
echo -e "Port SSL/TLS     : 443"
echo -e "BadVPN UDP       : 7100, 7300, 7300"
echo -e "========="
echo -e "Payload HTTP     :"
echo -e "GET / HTTP/1.1[crlf]Host: [host][crlf]Connection: upgrade[crlf]Upgrade: websocket[crlf][crlf]"
echo -e "========="
echo -e "Payload Enhanced :"
echo -e "GET / HTTP/1.1[crlf]Host: bug.com[crlf][crlf]PATCH / HTTP/1.1[crlf]Host: [host][crlf]Connection: upgrade[crlf]Upgrade: websocketk[crlf][crlf]"
echo -e "========="
