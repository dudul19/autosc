PERMISSION() {
    MYIP=$(curl -sS ipv4.icanhazip.com)
    TODAY_DATE=$(date +'%Y-%m-%d')
    AUTHORIZED_ENTRY=$(curl -sS ${LICENSE} | grep -w "$MYIP" | head -1)

    if [[ -n "$AUTHORIZED_ENTRY" ]]; then
        IP_FROM_ENTRY=$(echo "$AUTHORIZED_ENTRY" | awk '{print $4}')
        EXP_DATE_OR_LIFETIME_STATUS=$(echo "$AUTHORIZED_ENTRY" | awk '{print $3}') 

        if [ "$MYIP" = "$IP_FROM_ENTRY" ]; then
            if [[ "$EXP_DATE_OR_LIFETIME_STATUS" == "lifetime" ]]; then
                echo "Permission Accepted (Lifetime User)"
                echo "Akses Di Izinkan (Pengguna Lifetime)"
            elif [[ "$TODAY_DATE" < "$EXP_DATE_OR_LIFETIME_STATUS" ]]; then
                echo "Permission Accepted"
                echo "Akses Di Izinkan"
            elif [[ "$TODAY_DATE" == "$EXP_DATE_OR_LIFETIME_STATUS" ]]; then
                echo "Permission Accepted (Today is Expiry Date)"
                echo "Akses Di Izinkan (Hari Ini Kadaluarsa)"
            else
                echo "Permission Denied (Expired)"
                echo "Akses Di Tolak (Kadaluarsa)"
                read -n 1 -s -r -p "Press [ Enter ] to Exit"
                exit 1
            fi
        else
            echo "Permission Denied (IP Mismatch)"
            echo "Akses Di Tolak (IP Tidak Cocok)"
            read -n 1 -s -r -p "Press [ Enter ] to Exit"
            exit 1
        fi
    else
        echo "Permission Denied (IP Not Found)"
        echo "Akses Di Tolak (IP Tidak Ditemukan)"
        read -n 1 -s -r -p "Press [ Enter ] to Exit"
        exit 1
    fi
}

memasang_info() {
  MYIP=$(curl -sS ipv4.icanhazip.com)
  local izinsc="$LICENSE"
  
  local IP_DATA_LINE=$(curl -s "$izinsc" | grep -w "$MYIP" | head -1)

  username=$(echo "$IP_DATA_LINE" | awk '{print $2}')
  local exp=$(echo "$IP_DATA_LINE" | awk '{print $3}')

  local OS=$(lsb_release -d | cut -f2)
  local RAM_TOTAL=$(free -m | awk '/Mem:/ {print $2}')
  local RAM_USED=$(free -m | awk '/Mem:/ {print $3}')
  local UPTIME=$(uptime -p | sed 's/up //')
  local CPU_MODEL=$(awk -F ': ' '/^model name/ {name=$2} END {print name}' /proc/cpuinfo | head -n 1)
  local DOMAIN_VAL=$(cat /etc/xray/domain 2>/dev/null || echo "undefined")

  local TODAY_DATE_FORMATTED=$(date +'%Y-%m-%d')

  if [[ "$exp" == "lifetime" ]]; then
    EXPIRE_INFO="Lifetime (Unlimited Days) (Active)"
  elif [[ -n "$exp" ]]; then
    local exp_timestamp_val=$(date -d "$exp" +%s 2>/dev/null)
    local today_timestamp_val=$(date -d "$TODAY_DATE_FORMATTED" +%s 2>/dev/null)

    if [[ $? -eq 0 && -n "$exp_timestamp_val" && -n "$today_timestamp_val" ]]; then
      local days_left=$(((exp_timestamp_val - today_timestamp_val) / 86400))
      local expire_date_formatted=$(date -d "$exp" +"%d-%m-%Y" 2>/dev/null)
      
      local status_text="Active"
      if (( days_left <= 0 )); then
        status_text="Expired"
      elif (( days_left == 0 )); then
        status_text="Today Expired"
      fi
      EXPIRE_INFO="$expire_date_formatted $days_left Days $status_text"
    else
      EXPIRE_INFO="Invalid / Unknown Date" 
    fi
  else
    EXPIRE_INFO="Not Set"
  fi
}

